# ─── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Hosted demo: true tightens caps (3 participants / 3 rounds / 300 output tokens / $0.25 cap)
# and turns on per-IP daily rate limiting. Leave false for self-hosted BYOK use.
DEMO_MODE=false

# ─── Database (M3+) ─────────────────────────────────────────────────────
# Supabase pooled connection string (runtime).
# Omit entirely to run in in-memory dev mode — runs will not survive restart.
# DATABASE_URL=postgres://postgres:PASSWORD@db.PROJECT.supabase.co:6543/postgres?pgbouncer=true
# Direct, non-pooled connection used only by drizzle-kit for migrations.
# DIRECT_URL=postgres://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# ─── Model gateway ──────────────────────────────────────────────────────
# One of: mock | openrouter | vercel-ai-gateway
# "mock" requires no keys; other providers require the matching key below.
MODEL_GATEWAY_PROVIDER=mock

# OpenRouter — OpenAI-compatible, single key covers all provider slugs
# OPENROUTER_API_KEY=sk-or-v1-...

# Vercel AI Gateway — api key required locally; on Vercel deployments OIDC
# auth is auto-wired and the key is optional.
# VERCEL_AI_GATEWAY_API_KEY=vgk_...

# ─── TTS (M5) ───────────────────────────────────────────────────────────
# mock | elevenlabs  (google-tts/openai-tts stubbed — not implemented)
TTS_PROVIDER=mock
# Required when TTS_PROVIDER=elevenlabs. Free-tier keys work fine for demos.
# ELEVENLABS_API_KEY=
# Hard switch to disable audio generation server-side (e.g. during cost spikes).
DISABLE_TTS_GENERATION=false

# ─── Storage (M5) ───────────────────────────────────────────────────────
# local | vercel-blob | supabase | s3 | r2
# "local" is dev-only and is rejected at boot when VERCEL=1.
# "vercel-blob" is the hosted-demo default; BLOB_READ_WRITE_TOKEN is required
# when running locally (on Vercel the token is auto-injected).
STORAGE_PROVIDER=local
# BLOB_READ_WRITE_TOKEN=

# ─── Safety / cost caps ─────────────────────────────────────────────────
# Self-hoster values below are the floor; DEMO_MODE=true tightens these further
# (see src/lib/constants.ts HOSTED_DEMO_* values).
MAX_RUNS_PER_IP_PER_DAY=3
MAX_PARTICIPANTS_PER_RUN=6
MAX_ROUNDS_PER_RUN=6
MAX_OUTPUT_TOKENS_PER_CALL=400
MAX_ESTIMATED_COST_PER_RUN_USD=0.25

# Emergency flag: when true, no paid gateway call is made and the job tick
# returns drained:0 so nothing runs down the budget.
GLOBAL_AI_KILL_SWITCH=false

DISABLE_VIDEO_GENERATION=false

# ─── Jobs / tick drainer ────────────────────────────────────────────────
TICK_MAX_JOBS_PER_CALL=5
# Optional shared secret; when set, /api/jobs/tick demands `X-Jobs-Tick-Token`.
# Leave blank for client-triggered draining on Vercel Hobby.
# JOBS_TICK_TOKEN=

# ─── Moderation (M7) ────────────────────────────────────────────────────
# local  → keyword baseline (no key needed; default)
# openai → OpenAI Moderations API + keyword baseline; falls back to local
#          when OPENAI_API_KEY is unset.
MODERATION_PROVIDER=local
# OPENAI_API_KEY is also used by the optional `direct-openai` gateway when
# that adapter is implemented. Required when MODERATION_PROVIDER=openai.
# OPENAI_API_KEY=sk-...
